# Define a global platform for your project (Firebase pods require iOS 15+)
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  # Pin SDWebImage to 5.18.x — versions 5.19+ use iOS 17 HDR APIs not in Xcode 14.2 SDK
  pod 'SDWebImage', '~> 5.18.0'

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Disable strict concurrency to allow livekit_client to build on Xcode 14
      config.build_settings['SWIFT_STRICT_CONCURRENCY'] = 'minimal'
    end
  end

  # Patch SDWebImage: UIImage.isHighDynamicRange is iOS 17+ and not in Xcode 14.2 SDK
  sdwebimage_file = File.join(installer.sandbox.root, 'SDWebImage/SDWebImage/Core/UIImage+Metadata.m')
  if File.exist?(sdwebimage_file)
    content = File.read(sdwebimage_file)
    patched = content.gsub(
      /- \(BOOL\)sd_isHighDynamicRange \{.*?^\}/m,
      "- (BOOL)sd_isHighDynamicRange {\n    return [SDImageCoderHelper CGImageIsHDR:self.CGImage];\n}"
    )
    File.write(sdwebimage_file, patched) if patched != content
  end

  # Patch flutter_webrtc: AVCaptureDeviceTypeContinuityCamera/External are iOS 17+ only
  webrtc_file = Dir[File.join(installer.sandbox.root, '../.pub-cache/hosted/pub.dev/flutter_webrtc-*/ios/Classes/FlutterRTCMediaStream.m')].first
  webrtc_file ||= Dir["#{Dir.home}/.pub-cache/hosted/pub.dev/flutter_webrtc-*/ios/Classes/FlutterRTCMediaStream.m"].first
  if webrtc_file && File.exist?(webrtc_file)
    content = File.read(webrtc_file)
    patched = content.gsub(
      /if \(@available\(iOS 17\.0.*?AVCaptureDeviceTypeExternal.*?\]\);\s*\}/m,
      '// AVCaptureDeviceTypeContinuityCamera / External require iOS 17+ SDK — skipped for Xcode 14'
    )
    File.write(webrtc_file, patched) if patched != content
  end
end
